# Obtén estos valores desde Supabase: Project settings > API.
# No subas .env.local al repositorio.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Solo para rutas del servidor (por ejemplo, futuras rutas de IA).
# Nunca uses este valor en componentes del navegador.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: solo para inspecciones locales de metadatos mediante la Management API.
# No se usa en la aplicación ni se sube a GitHub.
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# IA conversacional del prospecto. Las llaves son exclusivas del servidor.
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile
